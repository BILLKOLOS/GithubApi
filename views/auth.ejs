<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page === 'login' ? 'Login' : 'Sign Up' %> · GitHub Contact Explorer</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #f6f8fa; --surface: #fff; --border: #d0d7de;
      --blue: #0969da; --blue-hover: #0550ae; --text: #24292f; --muted: #57606a;
    }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24px; }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 32px; width: 100%; max-width: 360px; }
    .logo { font-size: 28px; text-align: center; margin-bottom: 8px; }
    h1 { font-size: 20px; font-weight: 700; text-align: center; margin-bottom: 24px; }
    label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; color: var(--muted); }
    input { width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 14px; outline: none; margin-bottom: 14px; transition: border-color .15s; }
    input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(9,105,218,.12); }
    .btn { width: 100%; padding: 10px; background: var(--blue); color: #fff; border: none; border-radius: 6px; font-size: 14px; font-weight: 600; cursor: pointer; transition: background .15s; }
    .btn:hover { background: var(--blue-hover); }
    .btn-google { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 9px; background: var(--surface); border: 1px solid var(--border); border-radius: 6px; font-size: 14px; font-weight: 500; color: var(--text); text-decoration: none; margin-top: 12px; transition: background .15s; }
    .btn-google:hover { background: var(--bg); }
    .divider { display: flex; align-items: center; gap: 10px; margin: 16px 0; font-size: 12px; color: var(--muted); }
    .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }
    .footer-link { text-align: center; margin-top: 20px; font-size: 13px; color: var(--muted); }
    .footer-link a { color: var(--blue); text-decoration: none; }
    .footer-link a:hover { text-decoration: underline; }
    .error-box { background: #fff5f5; border: 1px solid #fca5a5; border-radius: 6px; padding: 10px 14px; color: #991b1b; font-size: 13px; margin-bottom: 16px; }
    .home-link { margin-bottom: 20px; font-size: 13px; color: var(--muted); text-decoration: none; }
    .home-link:hover { color: var(--blue); }
  </style>
</head>
<body>

<a class="home-link" href="/">← Back to search</a>

<div class="card">
  <div class="logo">🔍</div>
  <h1><%= page === 'login' ? 'Sign in' : 'Create account' %></h1>

  <% if (error) { %>
    <div class="error-box"><%= error %></div>
  <% } %>

  <form action="/<%= page %>" method="POST">
    <label for="username">Username / Email</label>
    <input type="text" id="username" name="username" autocomplete="username" required>

    <label for="password">Password</label>
    <input type="password" id="password" name="password" autocomplete="<%= page === 'login' ? 'current-password' : 'new-password' %>" required>

    <button type="submit" class="btn">
      <%= page === 'login' ? 'Sign in' : 'Create account' %>
    </button>
  </form>

  <div class="divider">or</div>

  <a class="btn-google" href="/auth/google">
    <svg width="16" height="16" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
    Continue with Google
  </a>
</div>

<div class="footer-link">
  <% if (page === 'login') { %>
    Don't have an account? <a href="/signup">Sign up</a>
  <% } else { %>
    Already have an account? <a href="/login">Sign in</a>
  <% } %>
</div>

</body>
</html>
