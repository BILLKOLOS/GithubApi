<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GitHub Contact Explorer</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f6f8fa;
      --surface: #ffffff;
      --border: #d0d7de;
      --blue: #0969da;
      --blue-hover: #0550ae;
      --text: #24292f;
      --muted: #57606a;
      --green: #1a7f37;
      --shadow: 0 1px 3px rgba(36,41,47,.08), 0 4px 16px rgba(36,41,47,.04);
    }

    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

    nav {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 56px;
    }
    .nav-brand { font-weight: 700; font-size: 16px; display: flex; align-items: center; gap: 8px; color: var(--text); text-decoration: none; }
    .nav-brand span { font-size: 20px; }
    .nav-links { display: flex; gap: 8px; align-items: center; }
    .nav-links a { font-size: 14px; color: var(--muted); text-decoration: none; padding: 6px 12px; border-radius: 6px; transition: background .15s; }
    .nav-links a:hover { background: var(--bg); color: var(--text); }
    .nav-links .btn-primary { background: var(--blue); color: #fff; font-size: 14px; padding: 6px 14px; border-radius: 6px; text-decoration: none; transition: background .15s; }
    .nav-links .btn-primary:hover { background: var(--blue-hover); }

    .hero {
      max-width: 720px;
      margin: 80px auto 0;
      padding: 0 24px 80px;
      text-align: center;
    }
    .hero-icon { font-size: 52px; margin-bottom: 20px; }
    .hero h1 { font-size: 32px; font-weight: 700; color: var(--text); margin-bottom: 12px; line-height: 1.2; }
    .hero p { font-size: 17px; color: var(--muted); margin-bottom: 40px; line-height: 1.6; }

    .search-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 28px;
      box-shadow: var(--shadow);
      text-align: left;
    }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
    .form-row.single { grid-template-columns: 1fr; }
    .form-row.four { grid-template-columns: 1fr 1fr 1fr 1fr; }

    label { display: block; font-size: 13px; font-weight: 600; color: var(--muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: .4px; }
    input[type="text"], select {
      width: 100%;
      padding: 9px 13px;
      border: 1px solid var(--border);
      border-radius: 6px;
      font-size: 14px;
      color: var(--text);
      background: var(--surface);
      outline: none;
      transition: border-color .15s, box-shadow .15s;
    }
    input[type="text"]:focus, select:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(9,105,218,.12); }

    .checkbox-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 13px;
      border: 1px solid var(--border);
      border-radius: 6px;
      cursor: pointer;
      transition: border-color .15s, background .15s;
      height: 38px;
    }
    .checkbox-row:has(input:checked) { border-color: var(--green); background: #f0fff4; }
    .checkbox-row input { width: 16px; height: 16px; accent-color: var(--green); cursor: pointer; margin: 0; }
    .checkbox-row span { font-size: 13px; font-weight: 600; color: var(--muted); white-space: nowrap; }
    .checkbox-row:has(input:checked) span { color: var(--green); }

    .btn-search {
      width: 100%;
      padding: 12px;
      background: var(--blue);
      color: #fff;
      border: none;
      border-radius: 6px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 6px;
      transition: background .15s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .btn-search:hover { background: var(--blue-hover); }

    .error-box {
      background: #fff5f5;
      border: 1px solid #fca5a5;
      border-radius: 8px;
      padding: 14px 16px;
      color: #991b1b;
      font-size: 14px;
      margin-bottom: 20px;
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }

    .features {
      max-width: 720px;
      margin: 32px auto 0;
      padding: 0 24px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      text-align: center;
    }
    .feature-item { padding: 16px; }
    .feature-item .icon { font-size: 24px; margin-bottom: 8px; }
    .feature-item strong { display: block; font-size: 14px; color: var(--text); margin-bottom: 4px; }
    .feature-item span { font-size: 13px; color: var(--muted); }

    @media (max-width: 600px) {
      .form-row { grid-template-columns: 1fr; }
      .form-row.four { grid-template-columns: 1fr 1fr; }
      .features { grid-template-columns: 1fr; }
      .hero h1 { font-size: 26px; }
    }
  </style>
</head>
<body>

<nav>
  <a class="nav-brand" href="/"><span>🔍</span> GitHub Contact Explorer</a>
  <div class="nav-links">
    <% if (user) { %>
      <span style="font-size:13px;color:var(--muted)"><%=user.displayName || user.username%></span>
      <a href="/logout">Logout</a>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/signup" class="btn-primary">Sign Up</a>
    <% } %>
  </div>
</nav>

<div class="hero">
  <div class="hero-icon">🌍</div>
  <h1>Find GitHub Developers & Their Contacts</h1>
  <p>Search GitHub users by location, tech stack, and activity. Extract emails, WhatsApp numbers, LinkedIn profiles and more — all in one place.</p>

  <% if (error) { %>
  <div class="error-box">⚠️ <div><%= error %></div></div>
  <% } %>

  <form class="search-card" action="/search" method="GET">
    <div class="form-row">
      <div>
        <label for="q">Search Keywords</label>
        <input type="text" id="q" name="q" placeholder="e.g. developer, engineer, react…">
      </div>
      <div>
        <label for="location">Location / Country</label>
        <input type="text" id="location" name="location" placeholder="e.g. Nairobi, Kenya, Zambia…">
      </div>
    </div>

    <div class="form-row four">
      <div>
        <label for="stack">Tech Stack</label>
        <select id="stack" name="stack">
          <% Object.entries(stacks).forEach(([key, s]) => { %>
            <option value="<%= key %>"><%= s.label %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="batch">Results</label>
        <select id="batch" name="batch">
          <option value="50">50 users</option>
          <option value="100">100 users</option>
          <option value="200">200 users</option>
        </select>
      </div>
      <div>
        <label>&nbsp;</label>
        <label class="checkbox-row">
          <input type="checkbox" name="active" value="true">
          <span>✅ Active only (3 mo)</span>
        </label>
      </div>
      <div>
        <label>&nbsp;</label>
        <button type="submit" class="btn-search" style="height:38px;margin-top:0;padding:0 14px;width:100%">
          Search →
        </button>
      </div>
    </div>
  </form>
</div>

<div class="features">
  <div class="feature-item">
    <div class="icon">📧</div>
    <strong>Email Extraction</strong>
    <span>Pulls public emails directly from GitHub profiles</span>
  </div>
  <div class="feature-item">
    <div class="icon">📱</div>
    <strong>WhatsApp Detection</strong>
    <span>Finds wa.me links & phone numbers in bios</span>
  </div>
  <div class="feature-item">
    <div class="icon">💼</div>
    <strong>LinkedIn + Others</strong>
    <span>Extracts LinkedIn, Twitter, Telegram & more</span>
  </div>
</div>

</body>
</html>
